# Firebase Console → Project settings → Your apps → Web app → SDK snippet (config object).
# Use the same Firestore project as the Flutter app.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics when set
VITE_FIREBASE_MEASUREMENT_ID=

# Optional — Cloud Functions region (must match deployment; default us-central1)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1
